# ============================================================
# CIRO - Environment Configuration
# Copy this file to .env and fill in your real values
# ============================================================

# ----------------------------------------------------------
# TWILIO (Real SMS/WhatsApp Dispatch)
# Get free trial at: https://www.twilio.com/try-twilio
# Free trial gives you ~$15 credit = ~150 SMS messages
# ----------------------------------------------------------
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890   # Your Twilio number

# ----------------------------------------------------------
# AUTHORITY CONTACT NUMBERS (Pakistani Emergency Services)
# Replace with real verified numbers for production
# For demo/testing: use your own number to receive alerts
# ----------------------------------------------------------
AUTHORITY_FIRE_BRIGADE=+923001234567         # Rescue 1122
AUTHORITY_TRAFFIC_POLICE=+923001234568       # Traffic Police HQ
AUTHORITY_NDMA=+923001234569                 # National Disaster Management Authority
AUTHORITY_EDHI=+923001234570                 # Edhi Foundation
AUTHORITY_RESCUE_MEDICAL=+923001234571       # Emergency Medical Services
AUTHORITY_WATER_BOARD=+923001234572          # WASA / Water Supply
AUTHORITY_CIVIL_DEFENCE=+923001234573        # Civil Defence
AUTHORITY_CITY_ADMIN=+923001234574           # City Administration / DC Office

# ----------------------------------------------------------
# DEMO MODE (set to true to use simulated dispatch only)
# When false, real SMS is attempted if Twilio keys exist
# ----------------------------------------------------------
DISPATCH_DEMO_MODE=false
